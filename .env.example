# ─────────────────────────────────────────────────────────────────────────────
# MarineDetailDirectory.com — Environment Variables
# Copy this file to .env.local and fill in all values before running locally.
# On Vercel, configure these in your project's Environment Variables dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# DATABASE — Neon PostgreSQL (Vercel Integration)
# ─────────────────────────────────────────────
# Get these from: Vercel Dashboard → Storage → Create Database → Neon Postgres
# The two URLs are required by Prisma with Neon's serverless driver:
#   DATABASE_URL  → uses the serverless/pooled connection (for queries)
#   DIRECT_URL    → uses the direct connection (for migrations)

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─────────────────────────────────────────────
# NEXT AUTH (Auth.js v5)
# ─────────────────────────────────────────────
# AUTH_SECRET: Run `npx auth secret` to generate a secure 32-byte secret.
#              Required in both development and production.
# AUTH_URL:    The full canonical URL of your deployment (no trailing slash).
#              Automatically set by Vercel in production; set manually for local dev.

AUTH_SECRET="your-32-char-secret-here-generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# VERCEL BLOB (File Storage)
# ─────────────────────────────────────────────
# Get these from: Vercel Dashboard → Storage → Create Store → Blob
# BLOB_READ_WRITE_TOKEN is required server-side to upload files.

BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ─────────────────────────────────────────────
# STRIPE (Payments — Phase 2 Implementation)
# ─────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_...) for development, LIVE keys (sk_live_...) for production.
# STRIPE_WEBHOOK_SECRET: Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
#                        Or run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`

STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STRIPE_PUBLISHABLE_KEY="pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ─────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────
# NEXT_PUBLIC_BASE_URL: Used for generating canonical URLs and Open Graph tags.
#                       No trailing slash.

NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Production example:
# NEXT_PUBLIC_BASE_URL="https://marinedetaildirectory.com"

# ─────────────────────────────────────────────
# NODE ENVIRONMENT
# ─────────────────────────────────────────────
# Automatically set by Vercel. Set manually for local dev if needed.

NODE_ENV="development"

// prisma/schema.prisma
// MarineDetailDirectory.com — Phase 1 Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  COMPANY
}

enum CompanyStatus {
  UNCLAIMED
  PENDING
  ACTIVE
  SUSPENDED
}

enum LeadStatus {
  NEW
  AVAILABLE
  PURCHASED
  EXPIRED
  REFUNDED
}

enum BoatSize {
  UNDER_20FT
  TWENTY_TO_30FT
  THIRTY_TO_40FT
  OVER_40FT
}

enum VehicleType {
  CAR
  BOAT
}

enum ServiceCategory {
  // Boat
  FULL_DETAIL
  HULL_CLEANING
  INTERIOR_DETAIL
  TEAK_RESTORATION
  WAXING_POLISHING
  BOTTOM_PAINT
  CANVAS_CLEANING
  BRIGHTWORK
  // Car
  CAR_FULL_DETAIL
  CAR_INTERIOR
  CAR_EXTERIOR
  PAINT_CORRECTION
  CERAMIC_COATING
  WINDOW_TINT
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// AUTH (Auth.js v5 / NextAuth required tables)
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           UserRole  @default(COMPANY)
  companyName    String?
  website        String?
  phone          String?
  homeBase       String?
  specialization String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  company              Company?
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// LOCATION HIERARCHY
// ─────────────────────────────────────────────

model State {
  id           String  @id @default(cuid())
  name         String  @unique
  slug         String  @unique
  abbreviation String  @unique
  metaTitle    String?
  metaDesc     String?
  contentBlock String? @db.Text

  cities City[]

  @@map("states")
}

model City {
  id           String   @id @default(cuid())
  stateId      String
  name         String
  slug         String
  county       String?
  latitude     Decimal? @db.Decimal(9, 6)
  longitude    Decimal? @db.Decimal(9, 6)
  population   Int?
  metaTitle    String?
  metaDesc     String?
  contentBlock String?  @db.Text
  isActive     Boolean  @default(true)

  state    State         @relation(fields: [stateId], references: [id])
  zipCodes ZipCode[]
  companies Company[]
  leads    Lead[]
  pages    ServicePage[]

  @@unique([stateId, slug])
  @@map("cities")
}

model ZipCode {
  id     String @id @default(cuid())
  code   String @unique
  cityId String

  city City @relation(fields: [cityId], references: [id])

  @@map("zip_codes")
}

// ─────────────────────────────────────────────
// SERVICE CATALOG
// ─────────────────────────────────────────────

model Service {
  id            String          @id @default(cuid())
  category      ServiceCategory @unique
  name          String
  slug          String          @unique
  description   String          @db.Text
  baseLeadPrice Decimal         @db.Decimal(8, 2) @default(15.00)

  companyServices CompanyService[]
  leads           Lead[]
  pages           ServicePage[]

  @@map("services")
}

model ServicePage {
  id           String  @id @default(cuid())
  cityId       String
  serviceId    String
  metaTitle    String
  metaDesc     String
  h1           String
  contentBlock String  @db.Text
  leadPrice    Decimal @db.Decimal(8, 2)
  isIndexed    Boolean @default(true)

  city    City    @relation(fields: [cityId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([cityId, serviceId])
  @@map("service_pages")
}

// ─────────────────────────────────────────────
// COMPANY
// ─────────────────────────────────────────────

model Company {
  id                String        @id @default(cuid())
  userId            String?       @unique
  cityId            String
  name              String
  slug              String        @unique
  status            CompanyStatus @default(UNCLAIMED)
  description       String?       @db.Text
  phone             String?
  email             String?
  website           String?
  address           String?
  zipCode           String?
  logoUrl           String?
  coverImageUrl     String?
  photoUrls         String[]
  yearEstablished   Int?
  licenseNumber     String?
  isInsured         Boolean       @default(false)
  isFeatured        Boolean       @default(false)
  averageRating     Decimal?      @db.Decimal(3, 2)
  reviewCount       Int           @default(0)
  stripeCustomerId  String?       @unique
  stripeAccountId   String?       @unique
  leadCreditBalance Decimal       @db.Decimal(10, 2) @default(0.00)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user          User?            @relation(fields: [userId], references: [id])
  city          City             @relation(fields: [cityId], references: [id])
  services      CompanyService[]
  reviews       Review[]
  leadPurchases LeadPurchase[]
  claimRequest  ClaimRequest?

  @@map("companies")
}

model CompanyService {
  id          String  @id @default(cuid())
  companyId   String
  serviceId   String
  customPrice String?
  isActive    Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([companyId, serviceId])
  @@map("company_services")
}

model ClaimRequest {
  id         String      @id @default(cuid())
  companyId  String      @unique
  userId     String
  message    String?     @db.Text
  proofUrl   String?
  status     ClaimStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@map("claim_requests")
}

// ─────────────────────────────────────────────
// REVIEWS (E-E-A-T / Schema.org)
// ─────────────────────────────────────────────

model Review {
  id          String           @id @default(cuid())
  companyId   String
  authorName  String
  authorEmail String?
  rating      Int
  title       String?
  body        String           @db.Text
  isVerified  Boolean          @default(false)
  isPublished Boolean          @default(false)
  serviceUsed ServiceCategory?
  publishedAt DateTime?
  createdAt   DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ─────────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────────

model Lead {
  id            String     @id @default(cuid())
  cityId        String
  serviceId     String
  status        LeadStatus @default(NEW)
  customerName  String
  customerEmail String
  customerPhone String
  vehicleType   VehicleType @default(BOAT)
  boatSize      BoatSize?
  boatType      String?
  boatYear      Int?
  boatMake      String?
  zipCode       String?
  notes         String?    @db.Text
  preferredDate DateTime?
  leadPrice     Decimal    @db.Decimal(8, 2)
  ipAddress     String?
  userAgent     String?    @db.Text
  referrerUrl   String?
  expiresAt     DateTime
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  city      City           @relation(fields: [cityId], references: [id])
  service   Service        @relation(fields: [serviceId], references: [id])
  purchases LeadPurchase[]

  @@map("leads")
}

// ─────────────────────────────────────────────
// LEAD PURCHASES
// ─────────────────────────────────────────────

model LeadPurchase {
  id                    String    @id @default(cuid())
  leadId                String
  companyId             String
  amountCharged         Decimal   @db.Decimal(8, 2)
  stripePaymentIntentId String?   @unique
  stripeChargeId        String?   @unique
  paidAt                DateTime?
  isRefunded            Boolean   @default(false)
  refundedAt            DateTime?
  refundReason          String?
  createdAt             DateTime  @default(now())

  lead    Lead    @relation(fields: [leadId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([leadId, companyId])
  @@map("lead_purchases")
}
